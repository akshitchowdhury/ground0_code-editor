# Copy to .env and fill in to enable real Google / GitHub sign-in via Firebase.
# Without these, the app runs in demo-auth mode (simulated sign-in).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# --- Ground0: Cloud backend (npm run server) ---
# Anthropic API key for AI-generated mock exams + feedback.
# Without it, exams use the built-in offline question bank.
ANTHROPIC_API_KEY=
# Postgres connection string, e.g. postgres://user:pass@localhost:5432/ground0
# Without it, the backend uses an in-memory store (data resets on restart).
DATABASE_URL=
# Backend port (Vite proxies /api to this). Default: 4000
PORT=4000
